{
  "name": "cmux-relay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "cmux-based terminal session streaming - monitor and control your cmux terminals from mobile",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter @cmux-relay/agent dev",
    "dev:relay": "pnpm --filter @cmux-relay/relay dev",
    "dev:web": "pnpm --filter web dev",
    "typecheck": "pnpm -r run typecheck",
    "test": "node --import tsx --test tests/integration.test.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "jsonwebtoken": "^9.0.3",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "ws": "^8.20.0"
  },
  "dependencies": {
    "esbuild": "^0.25.12"
  }
}
