{
  "name": "cmux-relay-agent",
  "version": "0.1.8",
  "type": "module",
  "bin": {
    "cmux-relay": "./dist/bin.cjs"
  },
  "files": [
    "dist/bin.cjs",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/bin.cjs --banner:js='#!/usr/bin/env node'",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@cmux-relay/shared": "workspace:*",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
