{
  "name": "cmux-relay-agent",
  "version": "0.2.7",
  "description": "Stream cmux terminal sessions to your phone — real-time monitoring for AI coding agents",
  "keywords": [
    "cmux",
    "terminal",
    "streaming",
    "mobile",
    "webrtc",
    "p2p",
    "xterm",
    "ghostty",
    "macos",
    "remote",
    "monitoring",
    "ai-agent",
    "claude-code",
    "codex",
    "developer-tools"
  ],
  "license": "MIT",
  "author": "Jongin Kim",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pallidev/cmux-relay.git",
    "directory": "packages/agent"
  },
  "homepage": "https://github.com/pallidev/cmux-relay#readme",
  "bugs": {
    "url": "https://github.com/pallidev/cmux-relay/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "cmux-relay": "./dist/bin.cjs"
  },
  "files": [
    "dist/bin.cjs",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/bin.cjs --external:node-datachannel --banner:js='#!/usr/bin/env node'",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "node-datachannel": "^0.32.3",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@cmux-relay/shared": "workspace:*",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
